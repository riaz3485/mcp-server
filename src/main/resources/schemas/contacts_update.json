{
  "description": "CRITICAL: ALWAYS call this tool - NEVER make up, guess, or fabricate data. Update an existing contact in Textellent",
  "inputSchema": {
    "type": "object",
    "properties": {
      "partnerClientCode": {
        "type": "string",
        "description": "Optional partner client code to call APIs on behalf of a specific partner office/sub-client. Only use when explicitly requested by the user."
      },
      "contactId": {
        "type": "string",
        "description": "The ID of the contact to update"
      },
      "contactData": {
        "type": "object",
        "properties": {
          "contactFirstName": {
            "type": "string",
            "description": "Contact first name"
          },
          "contactLastName": {
            "type": "string",
            "description": "Contact last name"
          },
          "phoneMobile": {
            "type": "string",
            "description": "Mobile phone number in E.164 format"
          },
          "phoneHome": {
            "type": "string",
            "description": "Home phone number"
          },
          "phoneWork": {
            "type": "string",
            "description": "Work phone number"
          },
          "phoneAlternate": {
            "type": "string",
            "description": "Alternate phone number"
          },
          "customFields": {
            "type": "object",
            "description": "Custom fields for the contact"
          }
        }
      }
    },
    "required": ["contactId", "contactData"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "statusCode": {
        "type": "string"
      },
      "message": {
        "type": "string"
      }
    }
  }
}
