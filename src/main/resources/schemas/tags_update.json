{
  "description": "Update an existing contact tag. Use this tool directly only when a single call to this tool is sufficient to complete the user's request; for any sequence of two or more tool calls, use the `batch_action` tool instead.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "tagId": {
        "type": "string",
        "description": "The ID of the tag to update"
      },
      "tagData": {
        "type": "object",
        "properties": {
          "tagName": {
            "type": "string",
            "description": "Name of the tag"
          },
          "signUpKeyword": {
            "type": "string",
            "description": "Sign-up keyword"
          },
          "shortCodeKeyword": {
            "type": "string",
            "description": "Short code keyword"
          },
          "sendConfirmationText": {
            "type": "integer",
            "description": "Whether to send confirmation text (0 or 1)"
          },
          "confirmationText": {
            "type": "string",
            "description": "Confirmation text message"
          },
          "sendFrom": {
            "type": "integer",
            "description": "Phone number ID to send from"
          }
        }
      }
    },
    "required": ["tagId", "tagData"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "statusCode": {
        "type": "string"
      },
      "message": {
        "type": "string"
      }
    }
  }
}
