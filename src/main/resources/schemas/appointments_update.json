{
  "description": "CRITICAL: ALWAYS call this tool - NEVER make up, guess, or fabricate data. Update an existing appointment. Invoke only as a step inside dsl_execute_plan.",
  "x-textellent-mcp": {
    "directToolsCall": false,
    "invocation": "dsl_step_only"
  },
  "inputSchema": {
    "type": "object",
    "properties": {
      "source": {
        "type": "string",
        "description": "Source system (e.g., ZOHO_BOOKING)"
      },
      "extId": {
        "type": "string",
        "description": "External ID for the appointment"
      },
      "appointmentData": {
        "type": "object",
        "properties": {
          "startDateTime": {
            "type": "string",
            "description": "Start date and time (YYYY-MM-DD HH:MM:SS)"
          },
          "endDateTime": {
            "type": "string",
            "description": "End date and time (YYYY-MM-DD HH:MM:SS)"
          },
          "serviceName": {
            "type": "string",
            "description": "Name of the service"
          },
          "customerFirstName": {
            "type": "string",
            "description": "Customer first name"
          },
          "customerLastName": {
            "type": "string",
            "description": "Customer last name"
          },
          "customerEmail": {
            "type": "string",
            "description": "Customer email address"
          },
          "phoneNumber": {
            "type": "string",
            "description": "Customer phone number in E.164 format"
          },
          "timeZone": {
            "type": "string",
            "description": "Time zone (e.g., America/New_York)"
          },
          "notes": {
            "type": "string",
            "description": "Appointment notes"
          },
          "status": {
            "type": "string",
            "description": "Appointment status (e.g., upcoming)"
          }
        }
      },
      "partnerClientCode": {
        "type": "string",
        "description": "Optional partner client code to call APIs on behalf of a specific partner office/sub-client. Only use when explicitly requested by the user."
      }
    },
    "required": [
      "appointmentData"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "statusCode": {
        "type": "string"
      },
      "message": {
        "type": "string"
      }
    }
  }
}
